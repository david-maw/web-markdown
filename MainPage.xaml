<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:web"
             BindingContext="{Binding Source={RelativeSource Self}}"
             x:DataType="local:MainPage"   
             Title="WebView Test"
             x:Class="web.MainPage">

    <ScrollView>
        <VerticalStackLayout
            Padding="30"
            Spacing="25">
            <Button Text="Open web page" Clicked="OnWebClicked" HorizontalOptions="Center" Margin="10"/>
            <HorizontalStackLayout HorizontalOptions="Center">
                <Label Text="Dark Mode" VerticalOptions="Center"/>
                <Switch IsToggled="{Binding Dark}"/>
            </HorizontalStackLayout>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
